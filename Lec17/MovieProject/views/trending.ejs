
     
<%-include('./header.ejs')-%>

     <div class="mt-3 d-flex flex-wrap justify-content-evenly">
        <% for(let movie of m){ %>
             
            <div class="card mb-3" style="max-width: 540px;">
  <div class="row g-0">
    <div class="col-md-4">
      <img src="<%=movie.img%>" class="img-fluid rounded-start" alt="...">
    </div>
    <div class="col-md-8">
      <div class="card-body">
        <h5 class="card-title"><%=movie.name%></h5>
        <p class="card-text"><%=movie.desc%></p>
        <p class="card-text"><small class="text-muted"><%=movie.year%></small></p>
         <p class="starability-result" data-rating="<%= movie.reviews.length!==0 ?( Math.floor( movie.reviews.reduce((acc, review) => acc + review.rating, 0)/movie.reviews.length) ): 0 %>" > </p>

         <h6>|RatedBy: <%=movie.reviews.length%></h6>
        <a href="/movies/<%=movie._id%>" class="btn btn-primary">view</a>
      </div>
    </div>
  </div>
</div>

        <%}%>
     </div>


     <%-include('./footer.ejs')-%>