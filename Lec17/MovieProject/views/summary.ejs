
<%-include('./header.ejs')-%>

<div class="card mb-3">
  <img style="width: 400px;" src="<%=m.img%>" class="card-img-top" alt="...">
  <div class="card-body">
    <h5 class="card-title"><%= data.title %></h5>
    <p class="card-text"> <%= data.summary %> </p>
    
    <p class="card-text"><small class="text-muted"><%= m.year %><span>Year of Release : </span> </small></p>
    <h4>Casts</h4>
    <% for(let s of data.cast){ %>
        <h6 class="card-text"> <%= s %> </h6>
   <% }%>
  </div>
</div>



<%-include('./footer.ejs')-%>