<%- layout('/main/boilerplate.ejs') -%>

<div class="d-flex justify-content-evenly">
<div class="mt-5">
     

    <div class="card ml-4 col col-lg-2" cols="6" style="width: 18rem; margin-left: 40px; width: 300px;">
  <img src="<%= product.img %>" class="card-img-top ml-3"  alt="...">
  <div class="card-body">
    <h4 class="card-title"><%=product.name%></h4>
    <h6 class="card-title">$ <%=product.price%></h6>
    <p class="card-text"><%=product.desc%></p>


    <button class="btn btn-primary" >Buy</button>
     <button class="btn btn-secondary" >Add To Cart</button>
     <a class="btn btn-warning" href="/products/<%=product._id%>/edit"> Edit</a>

     <form action="/products/<%=product._id%>/delete?_method=DELETE"    method="POST">
     <button type="submit" class="btn btn-danger"> Delete</button>
     </form>
    <!-- <a href="#" class="btn btn-primary">Go somewhere</a> -->
  </div>
</div>

</div>

<div class="pl-5 mt-5 reviews">
 <h1>Reviews Section</h1>
 <form action="/products/<%=product._id%>/reviews" method="POST">
  <div class="form-group">
    <label for="exampleInputEmail1">Rating :</label>
    <input type="range" name="rating" min="0" max="5" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Enter email">
    <!-- <small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small> -->
  </div>
  <div class="form-group mt-4">
    <label for="exampleInputEmail1">Leave your Comment :</label>
    <textarea rows="5"  name="comment" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Enter email"> </textarea>
    <!-- <small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small> -->
  </div>

  <button type="submit" class="btn btn-primary mt-2">Rate</button>
 </form>
</div>

</div>